# Raptor environment configuration template.
# Copy this file to .env and fill in the values, or export the variables in your shell.
# Do not commit .env to source control.

# --- Required ---

# Remote host address (hostname or IP address).
RAPTOR_SSH_HOST=

# SSH login username on the remote host.
RAPTOR_SSH_USER=

# --- Authentication (one of the following is required) ---

# Absolute path to the SSH private key file.
# This takes precedence over RAPTOR_SSH_PASSWORD when both are set.
RAPTOR_SSH_IDENTITY_FILE=

# SSH password. Ignored when RAPTOR_SSH_IDENTITY_FILE is set.
RAPTOR_SSH_PASSWORD=

# --- Optional SSH settings ---

# SSH port. Defaults to 22.
# RAPTOR_SSH_PORT=22

# Absolute path to a known_hosts file for strict host-key verification.
# When unset, host-key checking is disabled (acceptable for controlled environments).
# RAPTOR_SSH_KNOWN_HOSTS=~/.ssh/known_hosts

# --- Remote host layout (defaults shown) ---

# Path to the docker-compose file on the remote host.
# RAPTOR_COMPOSE_FILE=/opt/app/docker-compose.yml

# Absolute path to the deploy script on the remote host.
# Receives the target version string as its first argument.
# RAPTOR_DEPLOY_SCRIPT=/opt/app/scripts/deploy.sh

# Absolute path to the rollback script on the remote host.
# Receives the target version string as its first argument.
# RAPTOR_ROLLBACK_SCRIPT=/opt/app/scripts/rollback.sh

# Directory on the remote host that contains per-release sub-directories.
# RAPTOR_RELEASES_DIR=/opt/app/releases

# File on the remote host whose contents identify the currently active release.
# RAPTOR_CURRENT_RELEASE_FILE=/opt/app/current

# Append-only deployment history log on the remote host.
# RAPTOR_DEPLOY_HISTORY_FILE=/opt/app/deploy-history.log
